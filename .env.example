# Copy this file to .env and fill in the values. .env is gitignored.

# Slack bot token (xoxb-...), from api.slack.com/apps
SLACK_BOT_TOKEN=

# Groq API key (gsk_...), from console.groq.com
GROQ_API_KEY=

# Google service account credentials.
# Local dev: a path to the service account JSON key file.
# GitHub Actions: paste the full JSON content as the secret value instead.
GOOGLE_SERVICE_ACCOUNT_JSON=secrets/service-account.json

# Supabase project URL and service_role key (Project Settings > API)
SUPABASE_URL=
SUPABASE_KEY=

# Master Google Doc ID (the long string in the doc URL between /d/ and /edit)
MASTER_DOC_ID=

# Tab IDs for the two tabs. Run scripts/setup_master_doc.py to print these.
SUMMARIES_TAB_ID=
TRANSCRIPTS_TAB_ID=
